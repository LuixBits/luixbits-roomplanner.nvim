{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://roomplan.nvim/schema/v1/roomplan.schema.json",
  "title": "roomplan.nvim plan schema v1",
  "description": "Canonical one-floor RoomPlan document. Unknown members are deliberately allowed and preserved semantically by the runtime.",
  "type": "object",
  "required": [
    "format",
    "schema_version",
    "units",
    "rooms",
    "doors",
    "furniture",
    "custom_templates"
  ],
  "properties": {
    "format": { "const": "roomplan.nvim" },
    "schema_version": { "const": 1 },
    "units": { "const": "mm" },
    "metadata": { "$ref": "#/$defs/metadata", "default": { "name": "Untitled plan", "notes": "" } },
    "settings": {
      "$ref": "#/$defs/settings",
      "default": {
        "grid_mm": 100,
        "fine_step_mm": 10,
        "normal_step_mm": 100,
        "coarse_step_mm": 500,
        "default_door_width_mm": 900,
        "default_wall_thickness_mm": 120
      }
    },
    "rooms": {
      "type": "array",
      "maxItems": 10000,
      "items": { "$ref": "#/$defs/room" }
    },
    "doors": {
      "type": "array",
      "maxItems": 10000,
      "items": { "$ref": "#/$defs/door" }
    },
    "furniture": {
      "type": "array",
      "maxItems": 10000,
      "items": { "$ref": "#/$defs/furniture" }
    },
    "custom_templates": {
      "type": "array",
      "maxItems": 10000,
      "items": { "$ref": "#/$defs/custom_template" }
    },
    "extensions": { "type": "object", "default": {} }
  },
  "additionalProperties": true,
  "$defs": {
    "entity_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z][A-Za-z0-9._:-]{0,127}$"
    },
    "room_id": {
      "allOf": [
        { "$ref": "#/$defs/entity_id" },
        { "pattern": "^room-.+$" }
      ]
    },
    "door_id": {
      "allOf": [
        { "$ref": "#/$defs/entity_id" },
        { "pattern": "^door-.+$" }
      ]
    },
    "furniture_id": {
      "allOf": [
        { "$ref": "#/$defs/entity_id" },
        { "pattern": "^furniture-.+$" }
      ]
    },
    "custom_template_id": {
      "allOf": [
        { "$ref": "#/$defs/entity_id" },
        { "pattern": "^custom:.+$" }
      ]
    },
    "template_reference": {
      "allOf": [
        { "$ref": "#/$defs/entity_id" },
        { "pattern": "^(builtin:|custom:).+$" }
      ]
    },
    "display_string": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^[^\\u0000-\\u001F]+$"
    },
    "coordinate": {
      "type": "integer",
      "minimum": -1125899906842623,
      "maximum": 1125899906842623
    },
    "positive_local_mm": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1000000000
    },
    "nonnegative_local_mm": {
      "type": "integer",
      "minimum": 0,
      "maximum": 1000000000
    },
    "point_mm": {
      "type": "array",
      "prefixItems": [
        { "$ref": "#/$defs/coordinate" },
        { "$ref": "#/$defs/coordinate" }
      ],
      "items": false,
      "minItems": 2,
      "maxItems": 2
    },
    "size2_mm": {
      "type": "array",
      "prefixItems": [
        { "$ref": "#/$defs/positive_local_mm" },
        { "$ref": "#/$defs/positive_local_mm" }
      ],
      "items": false,
      "minItems": 2,
      "maxItems": 2
    },
    "size3_mm": {
      "type": "array",
      "prefixItems": [
        { "$ref": "#/$defs/positive_local_mm" },
        { "$ref": "#/$defs/positive_local_mm" },
        { "$ref": "#/$defs/positive_local_mm" }
      ],
      "items": false,
      "minItems": 3,
      "maxItems": 3
    },
    "metadata": {
      "type": "object",
      "properties": {
        "name": { "$ref": "#/$defs/display_string", "default": "Untitled plan" },
        "notes": {
          "type": "string",
          "maxLength": 1048576,
          "pattern": "^[^\\u0000-\\u0008\\u000B\\u000C\\u000E-\\u001F]*$",
          "default": ""
        }
      },
      "additionalProperties": true
    },
    "settings": {
      "type": "object",
      "properties": {
        "grid_mm": { "$ref": "#/$defs/positive_local_mm", "default": 100 },
        "fine_step_mm": { "$ref": "#/$defs/positive_local_mm", "default": 10 },
        "normal_step_mm": { "$ref": "#/$defs/positive_local_mm", "default": 100 },
        "coarse_step_mm": { "$ref": "#/$defs/positive_local_mm", "default": 500 },
        "default_door_width_mm": { "$ref": "#/$defs/positive_local_mm", "default": 900 },
        "default_wall_thickness_mm": { "$ref": "#/$defs/positive_local_mm", "default": 120 }
      },
      "additionalProperties": true
    },
    "room": {
      "type": "object",
      "required": ["id", "name", "origin_mm", "size_mm"],
      "properties": {
        "id": { "$ref": "#/$defs/room_id" },
        "name": { "$ref": "#/$defs/display_string" },
        "origin_mm": { "$ref": "#/$defs/point_mm" },
        "size_mm": { "$ref": "#/$defs/size2_mm" }
      },
      "additionalProperties": true
    },
    "door": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "room_id",
        "connects_to_room_id",
        "side",
        "offset_mm",
        "width_mm",
        "hinge",
        "opens_into",
        "open_angle_deg"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/door_id" },
        "kind": { "const": "hinged" },
        "room_id": { "$ref": "#/$defs/room_id" },
        "connects_to_room_id": {
          "anyOf": [
            { "$ref": "#/$defs/room_id" },
            { "type": "null" }
          ]
        },
        "side": { "enum": ["north", "east", "south", "west"] },
        "offset_mm": { "$ref": "#/$defs/nonnegative_local_mm" },
        "width_mm": { "$ref": "#/$defs/positive_local_mm" },
        "hinge": { "enum": ["start", "end"] },
        "opens_into": { "enum": ["owner", "connected", "outside"] },
        "open_angle_deg": { "type": "integer", "minimum": 1, "maximum": 180 }
      },
      "additionalProperties": true
    },
    "furniture": {
      "type": "object",
      "required": [
        "id",
        "room_id",
        "template_id",
        "name",
        "category",
        "center_mm",
        "size_mm",
        "rotation_deg"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/furniture_id" },
        "room_id": { "$ref": "#/$defs/room_id" },
        "template_id": { "$ref": "#/$defs/template_reference" },
        "name": { "$ref": "#/$defs/display_string" },
        "category": { "$ref": "#/$defs/display_string" },
        "center_mm": { "$ref": "#/$defs/point_mm" },
        "size_mm": { "$ref": "#/$defs/size3_mm" },
        "rotation_deg": { "enum": [0, 90, 180, 270] }
      },
      "additionalProperties": true
    },
    "custom_template": {
      "type": "object",
      "required": ["id", "name", "category", "shape", "default_size_mm"],
      "properties": {
        "id": { "$ref": "#/$defs/custom_template_id" },
        "name": { "$ref": "#/$defs/display_string" },
        "category": { "$ref": "#/$defs/display_string" },
        "shape": { "const": "rectangle" },
        "default_size_mm": { "$ref": "#/$defs/size3_mm" }
      },
      "additionalProperties": true
    }
  }
}
